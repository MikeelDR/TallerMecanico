<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Tema base de la aplicación -->
    <style name="Theme.TallerMecanico" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Colores principales -->
        <item name="colorPrimary">@color/celeste</item>
        <item name="colorPrimaryVariant">@color/celeste</item>
        <item name="colorOnPrimary">@color/black</item>

        <item name="colorSecondary">@color/celeste</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="colorSecondaryVariant">@color/celeste</item>
        <item name="colorAccent">@color/celeste</item>
        <item name="colorError">@color/red</item>
        <item name="colorOnError">@color/white</item>
        <item name="colorOnBackground">@color/black</item>

        <!-- Para botones, inputs, etc. -->
        <item name="colorSurface">@color/white</item>
        <item name="colorOnSurface">@color/black</item>

        <!-- Estilo para la ActionBar -->
        <item name="actionBarTheme">@style/ThemeOverlay.AppCompat.Dark.ActionBar</item>
    </style>
</resources>
