<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="300dp"
    android:height="200dp"
    android:viewportWidth="300"
    android:viewportHeight="200">

    <!-- Background rectangle -->
    <path
        android:fillColor="#E0E0E0"
        android:pathData="M0,0 L300,0 L300,200 L0,200 Z"/>

    <!-- Circular element -->
    <path
        android:fillColor="#BBBBBB"
        android:pathData="M150,50 m-50,0 a50,50 0,1 0 100,0 a50,50 0,1 0 -100,0"/>

    <!-- Use a group to position text -->
    <group
        android:translateX="75"
        android:translateY="180">
        <text
            android:textSize="16sp"
            android:fillColor="#666666"
            android:text="Vehicle Placeholder"/>
    </group>
</vector>