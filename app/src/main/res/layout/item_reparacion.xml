<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="10dp"
    android:layout_marginBottom="8dp">

    <!-- ID de la reparación -->
    <TextView
        android:id="@+id/tvReparacionId"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="ID: REP-001"
        android:textSize="12sp"
        android:textColor="@color/celeste"
        android:layout_marginBottom="4dp"/>

    <!-- ID del vehículo -->
    <TextView
        android:id="@+id/tvVehiculoId"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Vehículo: VEH-001"
        android:textSize="12sp"
        android:textColor="@color/celeste"
        android:layout_marginBottom="4dp"/>

    <!-- ID del mecánico -->
    <TextView
        android:id="@+id/tvMecanicoId"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Mecánico: MEC-001"
        android:textSize="12sp"
        android:textColor="@color/celeste"
        android:layout_marginBottom="4dp"/>

    <!-- Descripción de la reparación -->
    <TextView
        android:id="@+id/tvDescripcion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Descripción de la reparación"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp"/>

    <!-- Fecha de la reparación -->
    <TextView
        android:id="@+id/tvFecha"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Fecha: 01/01/2025"
        android:textSize="12sp"
        android:textColor="@color/celeste"
        android:layout_marginBottom="4dp"/>

    <!-- Costo de la reparación -->
    <TextView
        android:id="@+id/tvCosto"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Costo: $100"
        android:textSize="14sp"
        android:textColor="@color/celeste"
        android:layout_marginBottom="4dp"/>

    <!-- Estado de la reparación -->
    <TextView
        android:id="@+id/tvEstado"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Estado: Completada"
        android:textSize="14sp"
        android:textColor="@color/celeste" />
</LinearLayout>
